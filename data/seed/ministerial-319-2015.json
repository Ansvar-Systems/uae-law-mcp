    {
      "provision_ref": "s42",
      "section": "42",
      "title": "تتولىإدارةالتنميةالخضراءبوزارةالبيئةوالمياه مهاممقرر المجلسفي إعدادجداول أعمالوم",
      "content": "تتولىإدارةالتنميةالخضراءبوزارةالبيئةوالمياه مهاممقرر المجلسفي إعدادجداول أعمالومحاضراجتماعاتالمجلسومتابعةقراراتوتوصياتالمجلس بصورةمستمرة.",
      "language": "ar"
    },
    {
      "provision_ref": "s43",
      "section": "43",
      "title": "المادة5–محاضرالاجتماعات",
      "content": "المادة5–محاضرالاجتماعات",
      "language": "ar"
    },
    {
      "provision_ref": "s44",
      "section": "44",
      "title": "يعدمقرر المجلسمحضراً لكلجلسة، ويتضمنالمحضر قائمةبأسماءالأعضاءالحاضرينوغيرالحاضري",
      "content": "يعدمقرر المجلسمحضراً لكلجلسة، ويتضمنالمحضر قائمةبأسماءالأعضاءالحاضرينوغيرالحاضرين،وتدون فيهخلاصةالمناقشاتالتي تمت فيالاجتماعبالنسبة لكلموضوع منالمواضيعالمعروضة علىجدولالأعمال،والقراراتوالتوصياتالتي انتهىإليهاالمجلس،ويوقع المحضرمن رئيسالمجلس.",
      "language": "ar"
    },
    {
      "provision_ref": "s45",
      "section": "45",
      "title": "المادة6–تشكيلاللجان وفرقالعمل*",
      "content": "المادة6–تشكيلاللجان وفرقالعمل*",
      "language": "ar"
    },
    {
      "provision_ref": "s46",
      "section": "46",
      "title": "يجوزللمجلس تشكيللجان أو فرقعمل دائمة أومؤقتة من بينأعضائه أو منغيرهم لدراسةأو مت",
      "content": "يجوزللمجلس تشكيللجان أو فرقعمل دائمة أومؤقتة من بينأعضائه أو منغيرهم لدراسةأو متابعةالمواضيع ذاتالصلةباختصاصاتومهام المجلس.ويصدر بتشكيلتلك اللجان أوالفرق قرار منرئيسالمجلس.",
      "language": "ar"
    },
    {
      "provision_ref": "s47",
      "section": "47",
      "title": "لاتكوناجتماعاتالمجلس صحيحةإلا إذا حضرهاأكثر من نصفعدد أعضائهعلى الأقل،على أن يكو",
      "content": "لاتكوناجتماعاتالمجلس صحيحةإلا إذا حضرهاأكثر من نصفعدد أعضائهعلى الأقل،على أن يكون منبينهم رئيسالمجلس.",
      "language": "ar"
    },
    {
      "provision_ref": "s48",
      "section": "48",
      "title": "تتخذقراراتالمجلسبالأغلبيةالعاديةللأعضاءالحاضرين،وفي حالالتساوي يرجحالجانب الذيمن",
      "content": "تتخذقراراتالمجلسبالأغلبيةالعاديةللأعضاءالحاضرين،وفي حالالتساوي يرجحالجانب الذيمنه رئيسالمجلس. وتصدرقراراتالمجلسبتوقيع رئيسالمجلس.",
      "language": "ar"
    },
