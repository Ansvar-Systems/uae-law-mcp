    },
    {
      "provision_ref": "s5",
      "section": "5",
      "title": "بعدالاطلاع علىالقانونالاتحادي رقم 1لسنة 1972مفيشأن اختصاصاتالوزاراتوصلاحياتالوزر",
      "content": "بعدالاطلاع علىالقانونالاتحادي رقم 1لسنة 1972مفيشأن اختصاصاتالوزاراتوصلاحياتالوزراءوالقوانينالمعدلةله،",
      "language": "ar"
    },
    {
      "provision_ref": "s6",
      "section": "6",
      "title": "وعلىقانون (نظام)الحجرالزراعي لدولمجلس التعاونلدول الخليجالعربية لسنة2003م.",
      "content": "وعلىقانون (نظام)الحجرالزراعي لدولمجلس التعاونلدول الخليجالعربية لسنة2003م.",
      "language": "ar"
    },
    {
      "provision_ref": "s7",
      "section": "7",
      "title": "وعلىالقرارالوزاري رقم 248لعام 2003م بشأناللائحةالتنفيذيةلقانون (نظام)الحجرالزراع",
      "content": "وعلىالقرارالوزاري رقم 248لعام 2003م بشأناللائحةالتنفيذيةلقانون (نظام)الحجرالزراعي بدولمجلس التعاونلدول الخليجالعربية،",
      "language": "ar"
    },
    {
      "provision_ref": "s8",
      "section": "8",
      "title": "وعلىقرار مجلسالوزراء 27لسنة 2013 م بشأنالهيكلالتنظيميلوزارةالبيئةوالمياه،",
      "content": "وعلىقرار مجلسالوزراء 27لسنة 2013 م بشأنالهيكلالتنظيميلوزارةالبيئةوالمياه،",
      "language": "ar"
    },
    {
      "provision_ref": "s9",
      "section": "9",
      "title": "وبناءًعلى مقتضياتالمصلحةالعامة،",
      "content": "وبناءًعلى مقتضياتالمصلحةالعامة،",
      "language": "ar"
    },
    {
      "provision_ref": "s10",
      "section": "10",
      "title": "تعتبرالآفاتالمشار إليهافي الملحق رقم(1) من هذاالقرار آفاتحجرية.والآفاتالمشار إلي",
      "content": "تعتبرالآفاتالمشار إليهافي الملحق رقم(1) من هذاالقرار آفاتحجرية.والآفاتالمشار إليهافي الملحق رقم(2) آفات غيرحجرية تخضعللوائح.",
      "language": "ar"
    },
    {
      "provision_ref": "s11",
      "section": "11",
      "title": "تقومإدارة الصحةوالتنميةالزراعيةبتحديثالملحق (1)والملحق (2)وفقا لماتقتضيهالمصلحةا",
      "content": "تقومإدارة الصحةوالتنميةالزراعيةبتحديثالملحق (1)والملحق (2)وفقا لماتقتضيهالمصلحةالعامة.",
      "language": "ar"
    },
    {
      "provision_ref": "s12",
      "section": "12",
      "title": "يلغىكل حكم يخالفأحكام هذاالقرار أويتعارض معه.وينشر فيالجريدةالرسمية،ويعمل به منا",
      "content": "يلغىكل حكم يخالفأحكام هذاالقرار أويتعارض معه.وينشر فيالجريدةالرسمية،ويعمل به مناليوم التاليلتاريخنشره.",
      "language": "ar"
    },
